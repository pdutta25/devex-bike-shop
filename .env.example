# Admin API key — required in production to protect write operations.
# Set this to a strong random string (e.g. openssl rand -hex 32)
# In development (NODE_ENV=development), all admin operations are allowed without this key.
ADMIN_API_KEY=your-secret-key-here

# Admin login credentials
# Password is stored as a SHA-256 hash. Generate yours with:
#   echo -n "yourpassword" | shasum -a 256 | cut -d' ' -f1
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your-sha256-hash-here

# Secret used to sign admin session cookies (change in production)
ADMIN_SESSION_SECRET=change-me-to-a-random-string
